# ── Server ────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# Public URL used in download links — MUST match your Coolify domain
BASE_URL=https://your-app.yourdomain.com

# ── Security ───────────────────────────────────────────────────────────────────
# REQUIRED: generate a strong random key, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string

# ── Storage ────────────────────────────────────────────────────────────────────
STORAGE_PATH=storage/outputs
TEMP_PATH=storage/tmp

# ── Token / file expiry ────────────────────────────────────────────────────────
TOKEN_EXPIRY_HOURS=6

# ── Upload limits ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10

# ── Rate limiting (per IP) ─────────────────────────────────────────────────────
RATE_LIMIT_GENERATE=5/minute
